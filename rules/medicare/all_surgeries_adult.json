{
  "insurance": "medicare",
  "surgery": "all",
  "age_group": "adult",
  "provenance": {
    "source": "M Health Fairview CGC, Letter of Support Checklists (last updated 2026-03-09)",
    "policy": "CMS Article A53793 (billing/coding guidance)",
    "caveat": "General requirements that may change; verify against the member's specific plan. Items absent from the letter may be satisfied elsewhere (clinical notes, DA) -- do not auto-fail; route to human review.",
    "mapped_on": "2026-06-07",
    "verify_before_use": true
  },
  "requirements": [
    {
      "field": "age",
      "type": "min",
      "value": 18,
      "label": "All surgeries 18+"
    },
    {
      "field": "psychotherapy_duration_months",
      "type": "min",
      "value": 12,
      "label": "12 months of psychotherapy (not nec. consecutive)"
    },
    {
      "field": "diagnosed_gender_dysphoria",
      "type": "boolean",
      "value": true,
      "label": "Persistent chronic dysphoria >=6 months"
    },
    {
      "field": "gender_dysphoria_marked_and_sustained",
      "type": "boolean",
      "value": true,
      "label": "Clinically significant distress/impairment"
    },
    {
      "field": "comorbid_conditions_assessed",
      "type": "exists",
      "value": true,
      "label": "Identifies co-existing concerns, distinguishes from gender dysphoria"
    },
    {
      "field": "assessment_results_with_diagnoses",
      "type": "exists",
      "value": true,
      "label": "Assessment results including all diagnoses"
    },
    {
      "field": "months_living_as_identified_gender",
      "type": "min",
      "value": 12,
      "label": "12 months continuous full-time real-life experience"
    },
    {
      "field": "hormone_duration_months",
      "type": "min",
      "value": 12,
      "label": "12 consecutive months cross-sex hormones",
      "waived_if": [
        "hormones_not_desired_or_contraindicated"
      ]
    },
    {
      "field": "understands_risks",
      "type": "boolean",
      "value": true,
      "label": "Knowledge of practical surgical aspects"
    }
  ]
}
